generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  STANDARD
  SAME_DAY
}

enum PaymentMethod {
  COD
  GCASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model User {
  id                     Int      @id @default(autoincrement())
  name                   String
  email                  String   @unique
  password               String
  phone                  String?  @db.VarChar(20)
  role                   Role     @default(CUSTOMER)
  passwordResetToken     String?  @db.VarChar(64)
  passwordResetExpiresAt DateTime?
  cart                   Cart?
  orders                 Order[]
  pickerAssignments Order[] @relation("PickerOrders")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?     @db.Text
  image       String?     @db.VarChar(500)
  price       Decimal     @db.Decimal(10, 2)
  stock       Int
  unit        String      @default("pc") @db.VarChar(20)
  weight      Decimal?    @db.Decimal(10, 3)
  barcode     String?     @unique @db.VarChar(50)
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  cartItems   CartItem[]
  substitutedItems OrderItem[] @relation("SubstituteProduct")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@map("products")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id                Int            @id @default(autoincrement())
  userId            Int
  subtotal          Decimal        @default(0) @db.Decimal(10, 2)
  deliveryFee       Decimal        @default(0) @db.Decimal(10, 2)
  total             Decimal        @db.Decimal(10, 2)
  status            OrderStatus    @default(PENDING)
  paymentMethod     PaymentMethod  @default(COD)
  paymentStatus     PaymentStatus  @default(PENDING)
  paymentProvider   String?        @db.VarChar(50)
  paymentReference  String?        @db.VarChar(100)
  paymentCheckoutId String?        @db.VarChar(100)
  paidAt            DateTime?
  pickerId          Int?
  pickerNotes       String?        @db.Text
  deliverySlotId    Int?
  user              User           @relation(fields: [userId], references: [id])
  picker            User?          @relation("PickerOrders", fields: [pickerId], references: [id])
  deliverySlot      DeliverySlot?  @relation(fields: [deliverySlotId], references: [id])
  items             OrderItem[]
  delivery          Delivery?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([pickerId])
  @@index([deliverySlotId])
  @@index([paymentCheckoutId])
  @@map("orders")
}

model OrderItem {
  id                   Int      @id @default(autoincrement())
  orderId              Int
  productId            Int
  quantity             Int
  price                Decimal  @db.Decimal(10, 2)
  substituteProductId  Int?
  substitutionNote     String?  @db.VarChar(255)
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id])
  substituteProduct    Product? @relation("SubstituteProduct", fields: [substituteProductId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([substituteProductId])
  @@map("order_items")
}

model Delivery {
  id           Int            @id @default(autoincrement())
  orderId      Int            @unique
  address      String
  latitude     Decimal?       @db.Decimal(10, 7)
  longitude    Decimal?       @db.Decimal(10, 7)
  distanceKm   Decimal?       @db.Decimal(10, 2)
  deliveryFee  Decimal        @default(0) @db.Decimal(10, 2)
  status       DeliveryStatus @default(PENDING)
  type         DeliveryType   @default(SAME_DAY)
  estimatedAt  DateTime?
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("deliveries")
}

model DeliverySlot {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  startTime   String   @db.VarChar(5)
  endTime     String   @db.VarChar(5)
  maxOrders   Int      @default(5)
  bookedCount Int      @default(0)
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, startTime, endTime])
  @@map("delivery_slots")
}

model StoreConfig {
  id             Int     @id @default(autoincrement())
  storeName      String  @default("Decolores Grocery Store")
  latitude       Decimal @db.Decimal(10, 7)
  longitude      Decimal @db.Decimal(10, 7)
  deliveryRadius Decimal @default(5.0) @db.Decimal(5, 1)
  baseFee        Decimal @default(30.00) @db.Decimal(10, 2)
  perKmFee       Decimal @default(10.00) @db.Decimal(10, 2)

  @@map("store_config")
}
